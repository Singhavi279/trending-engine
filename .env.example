# Core App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_BASE_URL=http://localhost:3000

# Trending Sources
GOOGLE_TRENDS_URL=https://trends.google.com/trending/rss?geo=IN
GOOGLE_TRENDS_MAX=20
TWITTER_TRENDS_URL=https://trends24.in/india/
TWITTER_TRENDS_MAX=20
TOP_N=10

# Article Processing
MERGE_MAX_ARTICLES=2000

# LLM Intent Verification (Optional)
LLM_RERANK_ENABLED=false
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_INTENT_MIN_SCORE=0.5
NVIDIA_API_KEY=

# Persistence (Optional - for history tracking)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
